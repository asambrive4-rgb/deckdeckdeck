<Window x:Class="DeckDeckDeck.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:DeckDeckDeck.App.Views"
        xmlns:viewModels="clr-namespace:DeckDeckDeck.App.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="560"
        Height="680"
        MinWidth="500"
        MinHeight="620"
        Background="#F3F5F7"
        FontFamily="Segoe UI"
        PreviewKeyDown="OnPreviewKeyDown">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:CategoryViewModel}">
            <views:CategoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:CategoryEditViewModel}">
            <views:CategoryEditView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SnippetEditViewModel}">
            <views:SnippetEditView />
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="22"
                Background="White"
                BorderBrush="#D9DEE7"
                BorderThickness="1"
                CornerRadius="8">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Padding="12,8"
                Background="#EAF0F6"
                CornerRadius="8">
            <TextBlock Foreground="#485366"
                       FontSize="13"
                       Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</Window>
