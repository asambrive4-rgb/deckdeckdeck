<Window x:Class="DeckDeckDeck.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:DeckDeckDeck.App.Views"
        xmlns:viewModels="clr-namespace:DeckDeckDeck.App.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="440"
        Height="580"
        MinWidth="440"
        MinHeight="580"
        Style="{StaticResource Deck.MainWindowStyle}"
        ShowActivated="False"
        PreviewKeyDown="OnPreviewKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="Deck.ViewTransitionContainerStyle" TargetType="{x:Type Border}">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="CacheMode">
                <Setter.Value>
                    <BitmapCache />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.12" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
        <DataTemplate DataType="{x:Type viewModels:HomeViewModel}">
            <Border Style="{StaticResource Deck.ViewTransitionContainerStyle}">
                <views:HomeView />
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:CategoryViewModel}">
            <Border Style="{StaticResource Deck.ViewTransitionContainerStyle}">
                <views:CategoryView />
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:CategoryEditViewModel}">
            <Border Style="{StaticResource Deck.ViewTransitionContainerStyle}">
                <views:CategoryEditView />
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SnippetEditViewModel}">
            <Border Style="{StaticResource Deck.ViewTransitionContainerStyle}">
                <views:SnippetEditView />
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:HotkeyListViewModel}">
            <Border Style="{StaticResource Deck.ViewTransitionContainerStyle}">
                <views:HotkeyListView />
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:HotkeyEditViewModel}">
            <Border Style="{StaticResource Deck.ViewTransitionContainerStyle}">
                <views:HotkeyEditView />
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <Border Style="{StaticResource Deck.ViewTransitionContainerStyle}">
                <views:SettingsView />
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource Deck.Brush.Background.App}">
        <Border Style="{StaticResource Deck.WindowFrameBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource Deck.TopBarBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Command="{Binding TopBarBackCommand}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource Deck.TopBarBackButtonStyle}"
                                Visibility="{Binding ShowTopBarBackButton, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <TextBlock Grid.Column="1"
                                   Margin="8,0,12,0"
                                   Style="{StaticResource Deck.TopBarTitleTextStyle}"
                                   Text="{Binding TopBarTitle}"
                                   Visibility="{Binding ShowTopBarTitle, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <TextBlock Grid.Column="2"
                                   Margin="0,0,8,0"
                                   Style="{StaticResource Deck.TopBarStatusTextStyle}"
                                   Text="{Binding TopBarStatusMessage}" />

                        <Button Grid.Column="3"
                                Margin="0,0,8,0"
                                Command="{Binding TopBarSettingsCommand}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource Deck.TopBarSettingsButtonStyle}"
                                Visibility="{Binding ShowTopBarSettingsButton, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <StackPanel Grid.Column="4"
                                    Orientation="Horizontal"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button Click="OnMinimizeButtonClick"
                                    Style="{StaticResource Deck.WindowControlButtonStyle}"
                                    Content="{StaticResource Deck.Geometry.Minimize}"
                                    ToolTip="최소화" />
                            <Button Click="OnMaximizeRestoreButtonClick"
                                    Style="{StaticResource Deck.WindowControlButtonStyle}"
                                    Content="{StaticResource Deck.Geometry.Maximize}"
                                    ToolTip="최대화/복원" />
                            <Button Click="OnCloseButtonClick"
                                    Style="{StaticResource Deck.CloseWindowControlButtonStyle}"
                                    Content="{StaticResource Deck.Geometry.Close}"
                                    ToolTip="닫기" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource Deck.AppContentBorderStyle}">
                    <ContentControl Content="{Binding CurrentViewModel}" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
