<Window x:Class="DeckDeckDeck.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:DeckDeckDeck.App.Views"
        xmlns:viewModels="clr-namespace:DeckDeckDeck.App.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="560"
        Height="720"
        MinWidth="500"
        MinHeight="680"
        Style="{StaticResource Deck.MainWindowStyle}"
        ShowActivated="False"
        PreviewKeyDown="OnPreviewKeyDown">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:CategoryViewModel}">
            <views:CategoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:CategoryEditViewModel}">
            <views:CategoryEditView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SnippetEditViewModel}">
            <views:SnippetEditView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Deck.AppPanelBorderStyle}">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>

        <Border Grid.Row="1"
                Margin="0,8,0,0"
                Style="{StaticResource Deck.StatusPanelBorderStyle}">
            <TextBlock Style="{StaticResource Deck.StatusTextStyle}"
                       Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</Window>
