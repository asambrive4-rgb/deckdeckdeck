<UserControl x:Class="DeckDeckDeck.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock FontSize="28"
                       FontWeight="Bold"
                       Foreground="#162033"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,4,0,0"
                       FontSize="14"
                       Foreground="#69768A"
                       Text="실행 동작" />
        </StackPanel>

        <StackPanel Grid.Row="1">
            <CheckBox Margin="0,0,0,14"
                      Content="단축키로 열 때 창을 앞으로 표시"
                      FontSize="15"
                      IsChecked="{Binding BringWindowToFrontOnHotkey}" />
            <CheckBox Margin="0,0,0,14"
                      Content="붙여넣은 후 창 숨기기"
                      FontSize="15"
                      IsChecked="{Binding AutoHideAfterPaste}" />
            <CheckBox Margin="0,0,0,22"
                      Content="붙여넣은 후 클립보드 복원"
                      FontSize="15"
                      IsChecked="{Binding RestoreClipboardAfterPaste}" />

            <TextBlock Margin="0,0,0,6"
                       FontWeight="SemiBold"
                       Text="단축키" />
            <Border Padding="12"
                    Background="#F8FAFD"
                    BorderBrush="#DDE4EE"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding HomeHotkeyText}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding DirectCategoryHotkeysText}" />
                </StackPanel>
            </Border>

            <TextBlock Margin="0,18,0,6"
                       FontWeight="SemiBold"
                       Text="권한 안내" />
            <Border Padding="12"
                    Background="#FFF8E6">
                <TextBlock Foreground="#6F4E00"
                           Text="{Binding AdminPermissionNotice}"
                           TextWrapping="Wrap" />
            </Border>

            <TextBlock Margin="0,14,0,0"
                       Foreground="#B42318"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="2"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Width="82"
                    Height="36"
                    Margin="0,0,8,0"
                    Command="{Binding BackCommand}"
                    Content="뒤로" />
            <Button Grid.Column="2"
                    Width="82"
                    Height="36"
                    Command="{Binding SaveCommand}"
                    Content="저장" />
        </Grid>
    </Grid>
</UserControl>
