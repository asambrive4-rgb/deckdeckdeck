<UserControl x:Class="DeckDeckDeck.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DeckDeckDeck.App;component/Resources/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
            <CheckBox Margin="0,0,0,14"
                      Content="단축키로 열 때 창을 앞으로 표시"
                      Style="{StaticResource Deck.CheckBoxStyle}"
                      IsChecked="{Binding BringWindowToFrontOnHotkey}" />
            <CheckBox Margin="0,0,0,14"
                      Content="붙여넣은 후 창 숨기기"
                      Style="{StaticResource Deck.CheckBoxStyle}"
                      IsChecked="{Binding AutoHideAfterPaste}" />
            <CheckBox Margin="0,0,0,22"
                      Content="붙여넣은 후 클립보드 복원"
                      Style="{StaticResource Deck.CheckBoxStyle}"
                      IsChecked="{Binding RestoreClipboardAfterPaste}" />

            <TextBlock Style="{StaticResource Deck.FieldLabelTextStyle}"
                       Text="Spotify 연결" />
            <Border Margin="0,0,0,18"
                    Style="{StaticResource Deck.InfoPanelBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding SpotifyConnectionStatusText}"
                               TextWrapping="Wrap" />
                    <StackPanel Margin="0,10,0,0"
                                Visibility="{Binding ShowSpotifyConnectButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Command="{Binding ShowSpotifyConnectionFieldsCommand}"
                                Style="{StaticResource Deck.SecondaryButtonStyle}"
                                Content="Spotify 연결" />
                    </StackPanel>
                    <StackPanel Margin="0,10,0,0"
                                Visibility="{Binding ShowSpotifyConnectionFields, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Margin="0,0,0,10"
                                   Foreground="{StaticResource Deck.Brush.Text.Secondary}"
                                   Text="{Binding SpotifySetupIntro}"
                                   TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource Deck.FieldLabelTextStyle}"
                                   Text="1. Spotify Developer Dashboard를 엽니다." />
                        <Button HorizontalAlignment="Left"
                                Command="{Binding OpenSpotifyDeveloperDashboardCommand}"
                                Style="{StaticResource Deck.SecondaryButtonStyle}"
                                Content="Spotify Developer Dashboard 열기" />
                        <TextBlock Margin="0,12,0,6"
                                   Style="{StaticResource Deck.FieldLabelTextStyle}"
                                   Text="2. Dashboard에서 새 앱을 만듭니다." />
                        <TextBlock Foreground="{StaticResource Deck.Brush.Text.Secondary}"
                                   Text="App name 예시"
                                   TextWrapping="Wrap" />
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Height="36"
                                     IsReadOnly="True"
                                     Style="{StaticResource Deck.TextBoxStyle}"
                                     Text="{Binding SpotifyAppNameExample, Mode=OneWay}" />
                            <Button Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Command="{Binding CopySpotifyAppNameExampleCommand}"
                                    Style="{StaticResource Deck.SecondaryButtonStyle}"
                                    Content="복사" />
                        </Grid>
                        <TextBlock Foreground="{StaticResource Deck.Brush.Text.Secondary}"
                                   Text="App description 예시"
                                   TextWrapping="Wrap" />
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Height="36"
                                     IsReadOnly="True"
                                     Style="{StaticResource Deck.TextBoxStyle}"
                                     Text="{Binding SpotifyAppDescriptionExample, Mode=OneWay}" />
                            <Button Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Command="{Binding CopySpotifyAppDescriptionExampleCommand}"
                                    Style="{StaticResource Deck.SecondaryButtonStyle}"
                                    Content="복사" />
                        </Grid>
                        <TextBlock Margin="0,12,0,6"
                                   Style="{StaticResource Deck.FieldLabelTextStyle}"
                                   Text="3. Redirect URI를 등록하고 저장합니다." />
                        <TextBlock Margin="0,10,0,6"
                                   Foreground="{StaticResource Deck.Brush.Text.Secondary}"
                                   Text="{Binding SpotifyRedirectUriHelp}"
                                   TextWrapping="Wrap" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Height="36"
                                     IsReadOnly="True"
                                     Style="{StaticResource Deck.TextBoxStyle}"
                                     Text="{Binding SpotifyRedirectUri, Mode=OneWay}" />
                            <Button Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Command="{Binding CopySpotifyRedirectUriCommand}"
                                    Style="{StaticResource Deck.SecondaryButtonStyle}"
                                    Content="복사" />
                        </Grid>
                        <TextBlock Margin="0,12,0,6"
                                   Style="{StaticResource Deck.FieldLabelTextStyle}"
                                   Text="4. Spotify 앱 화면에서 Client ID를 복사합니다." />
                        <TextBlock Foreground="{StaticResource Deck.Brush.Text.Secondary}"
                                   Text="{Binding SpotifyClientIdHelp}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,12,0,6"
                                   Style="{StaticResource Deck.FieldLabelTextStyle}"
                                   Text="5. Client ID를 붙여넣고 연결을 시작합니다." />
                        <TextBlock Style="{StaticResource Deck.FieldLabelTextStyle}"
                                   Text="Spotify Client ID" />
                        <TextBox Height="36"
                                 Style="{StaticResource Deck.TextBoxStyle}"
                                 Text="{Binding SpotifyClientIdInput, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Margin="0,10,0,0"
                                HorizontalAlignment="Left"
                                Command="{Binding StartSpotifyConnectionCommand}"
                                Style="{StaticResource Deck.SecondaryButtonStyle}"
                                Content="연결 시작" />
                        <Border Margin="0,12,0,0"
                                Style="{StaticResource Deck.WarningPanelBorderStyle}">
                            <TextBlock Style="{StaticResource Deck.WarningTextStyle}"
                                       Text="{Binding SpotifyTroubleshootingText}" />
                        </Border>
                    </StackPanel>
                    <StackPanel Margin="0,10,0,0"
                                Visibility="{Binding ShowSpotifyConnectedActions, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Command="{Binding DisconnectSpotifyCommand}"
                                Style="{StaticResource Deck.SecondaryButtonStyle}"
                                Content="연결 해제" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Style="{StaticResource Deck.FieldLabelTextStyle}"
                       Text="자동 백업" />
            <Border Margin="0,0,0,18"
                    Style="{StaticResource Deck.InfoPanelBorderStyle}">
                <StackPanel>
                    <CheckBox Margin="0,0,0,10"
                              Content="변경 후 자동 백업 사용"
                              Style="{StaticResource Deck.CheckBoxStyle}"
                              IsChecked="{Binding AutoBackupEnabled}" />
                    <TextBlock Margin="0,0,0,8"
                               Foreground="{StaticResource Deck.Brush.Text.Secondary}"
                               Text="{Binding BackupFolderDisplay}"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding ChooseBackupFolderCommand}"
                                Style="{StaticResource Deck.SecondaryButtonStyle}"
                                Content="폴더 선택" />
                        <Button Margin="8,0,0,0"
                                Command="{Binding CreateManualBackupCommand}"
                                Style="{StaticResource Deck.SecondaryButtonStyle}"
                                Content="즉시 백업" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Style="{StaticResource Deck.FieldLabelTextStyle}"
                       Text="단축키" />
            <Border Style="{StaticResource Deck.InfoPanelBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding HomeHotkeyText}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding MinimizeHotkeyText}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding DirectCategoryHotkeysText}" />
                </StackPanel>
            </Border>

            <TextBlock Margin="0,18,0,6"
                       Style="{StaticResource Deck.FieldLabelTextStyle}"
                       Text="권한 안내" />
            <Border Style="{StaticResource Deck.WarningPanelBorderStyle}">
                <TextBlock Style="{StaticResource Deck.WarningTextStyle}"
                           Text="{Binding AdminPermissionNotice}" />
            </Border>

            <TextBlock Margin="0,14,0,0"
                       Style="{StaticResource Deck.ErrorTextStyle}"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1"
              Style="{StaticResource Deck.FooterActionsGridStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Margin="0,0,8,0"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource Deck.FooterButtonStyle}"
                    Content="뒤로" />
            <Button Grid.Column="2"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource Deck.PrimaryFooterButtonStyle}"
                    Content="저장" />
        </Grid>
    </Grid>
</UserControl>
