<UserControl x:Class="DeckDeckDeck.App.Views.HotkeyListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Border Style="{StaticResource Deck.InfoPanelBorderStyle}"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource Deck.PageTitleTextStyle}"
                               Text="등록된 핫키가 없습니다"
                               TextAlignment="Center" />
                    <TextBlock Margin="0,10,0,18"
                               Style="{StaticResource Deck.PageSubtitleTextStyle}"
                               Text="핫키를 추가하면 한 번의 키 입력으로 동작을 실행할 수 있습니다."
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                    <Button Command="{Binding AddCommand}"
                            Style="{StaticResource Deck.PrimaryButtonStyle}"
                            Content="핫키 추가" />
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Deck.InfoPanelBorderStyle}"
                                    Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Style="{StaticResource Deck.FieldLabelTextStyle}"
                                                   Text="{Binding Title}" />
                                        <TextBlock Style="{StaticResource Deck.StatusTextStyle}"
                                                   Text="{Binding HotkeyText}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Style="{StaticResource Deck.StatusTextStyle}"
                                                   Text="{Binding ActionTypeText}" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Style="{StaticResource Deck.StatusTextStyle}"
                                                   Text="{Binding Summary}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Style="{StaticResource Deck.StatusTextStyle}"
                                                   Text="{Binding EnabledText}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Margin="14,0,0,0"
                                                VerticalAlignment="Center">
                                        <Button Command="{Binding EditCommand}"
                                                Style="{StaticResource Deck.ImageActionButtonStyle}"
                                                Content="편집" />
                                        <Button Margin="0,8,0,0"
                                                Command="{Binding ToggleEnabledCommand}"
                                                Style="{StaticResource Deck.ImageActionButtonStyle}"
                                                Content="{Binding ToggleEnabledText}" />
                                        <Button Margin="0,8,0,0"
                                                Command="{Binding DeleteCommand}"
                                                Style="{StaticResource Deck.DangerButtonStyle}"
                                                Content="삭제" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="1"
              Style="{StaticResource Deck.FooterActionsGridStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1"
                    Command="{Binding AddCommand}"
                    Style="{StaticResource Deck.PrimaryButtonStyle}"
                    Content="핫키 추가" />
        </Grid>
    </Grid>
</UserControl>
