<UserControl x:Class="DeckDeckDeck.App.Views.SnippetEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock FontSize="28"
                       FontWeight="Bold"
                       Foreground="#162033"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,4,0,0"
                       FontSize="14"
                       Foreground="#69768A">
                <Run Text="{Binding CategoryName, Mode=OneWay}" />
                <Run Text=" / 슬롯 " />
                <Run Text="{Binding KeyText, Mode=OneWay}" />
            </TextBlock>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Margin="0,0,0,6"
                               FontWeight="SemiBold"
                               Text="슬롯 명" />
                    <TextBox Height="36"
                             Padding="8,6"
                             Text="{Binding SnippetTitle, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Margin="0,14,0,0">
                    <TextBlock Margin="0,0,0,6"
                               FontWeight="SemiBold"
                               Text="실행" />
                    <TextBox MinHeight="180"
                             Padding="8"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Margin="0,14,0,0">
                    <TextBlock Margin="0,0,0,6"
                               FontWeight="SemiBold"
                               Text="설명" />
                    <TextBox Height="70"
                             Padding="8"
                             AcceptsReturn="True"
                             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>

                <CheckBox Grid.Row="3"
                          Margin="0,14,0,0"
                          Content="이 슬롯 사용"
                          FontWeight="SemiBold"
                          IsChecked="{Binding IsSlotEnabled}" />

                <StackPanel Grid.Row="4"
                            Margin="0,14,0,0">
                    <TextBlock Margin="0,0,0,6"
                               FontWeight="SemiBold"
                               Text="이미지" />
                    <DockPanel LastChildFill="False">
                        <Border Width="72"
                                Height="72"
                                Background="#F3F5F7"
                                BorderBrush="#CBD3DF"
                                BorderThickness="1">
                            <Image Source="{Binding ThumbnailPath}"
                                   Stretch="Uniform" />
                        </Border>
                        <StackPanel Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                            <Button Width="120"
                                    Height="32"
                                    Command="{Binding ChooseImageCommand}"
                                    Content="이미지 선택" />
                            <Button Width="120"
                                    Height="32"
                                    Margin="0,8,0,0"
                                    Command="{Binding RemoveImageCommand}"
                                    Content="이미지 제거"
                                    IsEnabled="{Binding HasImage}" />
                        </StackPanel>
                    </DockPanel>
                </StackPanel>

                <TextBlock Grid.Row="5"
                           Margin="0,14,0,0"
                           Foreground="#B42318"
                           Text="{Binding ErrorMessage}"
                           TextWrapping="Wrap" />
            </Grid>
        </ScrollViewer>

        <Grid Grid.Row="2"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Width="82"
                    Height="36"
                    Command="{Binding DeleteCommand}"
                    Content="삭제"
                    IsEnabled="{Binding CanDelete}" />
            <Button Grid.Column="2"
                    Width="82"
                    Height="36"
                    Margin="0,0,8,0"
                    Command="{Binding CancelCommand}"
                    Content="취소" />
            <Button Grid.Column="3"
                    Width="82"
                    Height="36"
                    Command="{Binding SaveCommand}"
                    Content="저장" />
        </Grid>
    </Grid>
</UserControl>
