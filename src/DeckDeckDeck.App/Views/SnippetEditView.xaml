<UserControl x:Class="DeckDeckDeck.App.Views.SnippetEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock FontSize="28"
                       FontWeight="Bold"
                       Foreground="#162033"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,4,0,0"
                       FontSize="14"
                       Foreground="#69768A">
                <Run Text="{Binding CategoryName, Mode=OneWay}" />
                <Run Text=" / Slot " />
                <Run Text="{Binding KeyText, Mode=OneWay}" />
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Margin="0,0,0,6"
                           FontWeight="SemiBold"
                           Text="Title" />
                <TextBox Height="36"
                         Padding="8,6"
                         Text="{Binding SnippetTitle, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Margin="0,14,0,0">
                <TextBlock Margin="0,0,0,6"
                           FontWeight="SemiBold"
                           Text="Content" />
                <TextBox MinHeight="180"
                         Padding="8"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Margin="0,14,0,0">
                <TextBlock Margin="0,0,0,6"
                           FontWeight="SemiBold"
                           Text="Description" />
                <TextBox Height="70"
                         Padding="8"
                         AcceptsReturn="True"
                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>

            <TextBlock Grid.Row="3"
                       Margin="0,14,0,0"
                       Foreground="#B42318"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />
        </Grid>

        <Grid Grid.Row="2"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Width="82"
                    Height="36"
                    Command="{Binding DeleteCommand}"
                    Content="Delete"
                    IsEnabled="{Binding CanDelete}" />
            <Button Grid.Column="2"
                    Width="82"
                    Height="36"
                    Margin="0,0,8,0"
                    Command="{Binding CancelCommand}"
                    Content="Cancel" />
            <Button Grid.Column="3"
                    Width="82"
                    Height="36"
                    Command="{Binding SaveCommand}"
                    Content="Save" />
        </Grid>
    </Grid>
</UserControl>
