<UserControl x:Class="DeckDeckDeck.App.Views.NumpadGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="380">
    <UserControl.Resources>
        <Style x:Key="SlotButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="MinHeight" Value="76" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CBD3DF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#162033" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#5F6C80"
                                       Text="{Binding KeyText}" />
                            <TextBlock Grid.Row="1"
                                       Margin="0,8,0,6"
                                       FontSize="19"
                                       FontWeight="SemiBold"
                                       Text="{Binding DisplayText}"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Row="2"
                                       FontSize="11"
                                       Foreground="#738096"
                                       Text="{Binding Caption}"
                                       TextAlignment="Right" />
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4977C2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DBE8FA" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                    <Setter Property="Background" Value="#F8FAFD" />
                    <Setter Property="BorderBrush" Value="#DDE4EE" />
                    <Setter Property="Foreground" Value="#64748B" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Button Grid.Row="0" Grid.Column="0"
                Content="{Binding}"
                DataContext="{Binding NumpadDivide}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />
        <Button Grid.Row="0" Grid.Column="1"
                Content="{Binding}"
                DataContext="{Binding NumpadMultiply}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />
        <Button Grid.Row="0" Grid.Column="2"
                Content="{Binding}"
                DataContext="{Binding NumpadSubtract}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />

        <Button Grid.Row="1" Grid.Column="0"
                Content="{Binding}"
                DataContext="{Binding Numpad7}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />
        <Button Grid.Row="1" Grid.Column="1"
                Content="{Binding}"
                DataContext="{Binding Numpad8}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />
        <Button Grid.Row="1" Grid.Column="2"
                Content="{Binding}"
                DataContext="{Binding Numpad9}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />
        <Button Grid.Row="1" Grid.Column="3" Grid.RowSpan="2"
                Content="{Binding}"
                DataContext="{Binding NumpadAdd}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />

        <Button Grid.Row="2" Grid.Column="0"
                Content="{Binding}"
                DataContext="{Binding Numpad4}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />
        <Button Grid.Row="2" Grid.Column="1"
                Content="{Binding}"
                DataContext="{Binding Numpad5}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />
        <Button Grid.Row="2" Grid.Column="2"
                Content="{Binding}"
                DataContext="{Binding Numpad6}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />

        <Button Grid.Row="3" Grid.Column="0"
                Content="{Binding}"
                DataContext="{Binding Numpad1}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />
        <Button Grid.Row="3" Grid.Column="1"
                Content="{Binding}"
                DataContext="{Binding Numpad2}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />
        <Button Grid.Row="3" Grid.Column="2"
                Content="{Binding}"
                DataContext="{Binding Numpad3}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />

        <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                Content="{Binding}"
                DataContext="{Binding Numpad0}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />
        <Button Grid.Row="4" Grid.Column="2"
                Content="{Binding}"
                DataContext="{Binding NumpadDecimal}"
                Command="{Binding SelectCommand}"
                IsEnabled="{Binding IsEnabledSlot}"
                Style="{StaticResource SlotButtonStyle}" />
    </Grid>
</UserControl>
