<UserControl x:Class="DeckDeckDeck.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DeckDeckDeck.App.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock FontSize="28"
                       FontWeight="Bold"
                       Foreground="#162033"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,4,0,0"
                       FontSize="14"
                       Foreground="#69768A"
                       Text="{Binding Subtitle}" />
        </StackPanel>

        <views:NumpadGridView Grid.Row="1"
                              DataContext="{Binding NumpadGrid}" />
    </Grid>
</UserControl>
